generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Model {
  id          String   @id @default(cuid())
  name        String   @unique // slug identifier, e.g. "classic-floral"
  label       String
  description String

  // React component name used to render invitations with this model (e.g. "ClassicFloral")
  component   String

  // Optional preview image URL shown in admin model picker
  previewImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations Invitation[]
}

model Invitation {
  id           String   @id @default(cuid())
  slug         String   @unique
  modelId      String
  model        Model    @relation(fields: [modelId], references: [id])
  couple       Json     // { bride, groom, monogram }
  date         Json     // { iso, display, dayOfWeek, time, day, month, year }
  quote        String
  location     Json     // { name, address, googleMapsUrl, wazeUrl?, latitude?, longitude?, imageUrl? }
  location2    Json?    // Optional second location — same shape as location
  rsvp         Json     // { enabled, deadline? }
  schedule     Json     // ScheduleEvent[]
  dressCode    Json     // { enabled, text }
  giftRegistry Json     // { enabled, text, link? }
  audio        Json     // { enabled, src, artist, title }
  heroImage    String
  videoUrl     String?
  faqs         Json?    // FAQItem[]
  guestGuide   Json?    // GuestGuide { enabled, items[] }
  cinematicImageUrl String? // background image for the cinematic Save the Date style
  sectionImages  Json?   // SectionImages { image1?, image2?, image3?, image4? }
  parents        Json?   // ParentsInfo { enabled, blessingMessage, inviteMessage, bridesFather, bridesMother, groomsFather, groomsMother }
  ourStory       Json?   // OurStory { enabled, title, description }
  styles         Json    // InvitationStyles — all visual styling (colors, fonts, CTA, envelope, text/card overrides)
  imageSettings  Json?   // ImageSettingsMap — per-image position & zoom overrides
  customTexts    Json?   // CustomTexts — per-invitation UI text overrides (section titles, buttons, RSVP labels, etc.)
  invitationType String  @default("standard") // "standard" | "external_video" | "external_link"
  externalLink   String? // URL for the external link / iframe (external_link type)
  ownerToken   String   @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rsvpResponses RsvpResponse[]
  events        InvitationEvent[]
}

model InvitationEvent {
  id             String     @id @default(cuid())
  invitationSlug String
  invitation     Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  /// "page_view" | "envelope_open" | "maps_click" | "waze_click" | "gift_click" | "audio_play" | "calendar_click" | "rsvp_submit"
  type      String
  visitorId String
  sessionId String
  device    String?
  referrer  String?

  createdAt DateTime @default(now())

  @@index([invitationSlug])
  @@index([invitationSlug, type])
  @@index([createdAt])
}

model RsvpResponse {
  id                  String   @id @default(cuid())
  invitationSlug      String
  guestName           String
  email               String?
  attending           Boolean
  dietaryRestrictions String?
  message             String?
  submittedAt         DateTime @default(now())

  invitation Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  @@index([invitationSlug])
}
