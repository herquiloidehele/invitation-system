generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Theme {
  id          String   @id @default(cuid())
  name        String   @unique // slug identifier, e.g. "pink-floral"
  label       String
  description String

  // Envelope appearance stored as JSON { base, topFlap, bottomFlap }
  envelope Json

  // Page background & card styling
  bg         String
  cardBg     String
  cardBorder String

  // Color palette
  primary   String
  secondary String
  accent    String

  // Text colors
  textPrimary   String
  textSecondary String
  textMuted     String

  // Typography
  displayFont      String
  bodyFont         String
  scriptFont       String?
  uiFont           String
  sectionTitleFont     String?
  sectionTitleFontSize  Float?
  sectionTitleFontWeight String?

  // CTA button styling
  ctaPrimaryBg       String
  ctaPrimaryText     String
  ctaSecondaryBorder String
  ctaSecondaryText   String
  ctaRadius          String

  // Cover text colors
  monogramColor String
  tapTextColor  String

  // Atmospheric / decorative
  bgGradient      String?
  decorativeColor String
  ctaGlow         String?

  // Layout selector — controls which renderer is used in InvitationView.
  // "default" routes to the standard envelope+InvitationPage flow.
  // "curtain-canva" routes to the new CurtainCanvaPage flow.
  layout String @default("default")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations Invitation[]
}

model Invitation {
  id           String   @id @default(cuid())
  slug         String   @unique
  themeId      String
  theme        Theme    @relation(fields: [themeId], references: [id])
  couple       Json     // { bride, groom, monogram }
  date         Json     // { iso, display, dayOfWeek, time, day, month, year }
  quote        String
  location     Json     // { name, address, googleMapsUrl, wazeUrl?, latitude?, longitude?, imageUrl? }
  location2    Json?    // Optional second location — same shape as location
  rsvp         Json     // { enabled, deadline? }
  schedule     Json     // ScheduleEvent[]
  scheduleStyle String? // "default" | "illustrated"
  dressCode    Json     // { enabled, text }
  giftRegistry Json     // { enabled, text, link? }
  audio        Json     // { enabled, src, artist, title }
  heroImage    String
  heroHeight   Int?     // Pixel height for image-based heroes. Null falls back to 300px in the renderer.
  heroOverlay  Json?    // HeroOverlayConfig { scrimOpacity?, gradientStart? } — controls dark scrim (video only) + bottom gradient.
  heroScrollIndicator Json? // HeroScrollIndicatorConfig { enabled, color? } — toggles the animated scroll-down arrow shown above the audio player.
  videoUrl     String?  // Hero background video (InvitationHero on standard invitations; the looping full-screen hero on curtain-canva).
  videoPoster  String?  // Poster for videoUrl (the hero video). Optional.
  heroMediaFit String?  // "cover" | "contain" | "fill" | "scale-down" | "none"; null => "cover". CSS object-fit for hero video + standard hero image.
  curtainVideoUrl String?  // Curtain-canva only: the curtain animation video played on tap. Empty → bundled default.
  curtainVideoPoster String? // Poster for curtainVideoUrl — the closed-curtain still shown (esp. on iOS) while the curtain video loads.
  heroRevealSeconds Float?  // Video-entrance: seconds into the entrance video at which the hero text reveals. Null → default (5s).
  heroTopText  String?  // Video-entrance: top text line shown above the couple names in the hero.
  heroTapPrompt Boolean @default(true) // Video-entrance: show the cover prompt (play button + tap hint) before tapping. False hides it.
  heroTextLayer Json?   // HeroTextLayer { hideDefaultText, blocks[] } — free-positioned custom text over the hero media.
  faqs         Json?    // FAQItem[]
  guestGuide   Json?    // GuestGuide { enabled, items[] }
  envelope     Json?    // EnvelopeConfig { base?, coverBackground?, topFlap?, bottomFlap?, shimmer? }
  saveDateStyle  String? // "classic" | "countdown" | "quad-cards" | "cinematic" | "minimal-line"
  cinematicImageUrl String? // background image for the cinematic Save the Date style
  sectionImages  Json?   // SectionImages { image1?, image2?, image3?, image4? }
  coupleGallery  Json?   // CoupleGallery { enabled, style, images[], title?, autoplay? }
  places         Json?   // PlacesConfig — optional recommended places (hotels, restaurants, attractions) section
  parents        Json?   // ParentsInfo { enabled, blessingMessage, inviteMessage, bridesFather, bridesMother, groomsFather, groomsMother }
  ourStory       Json?   // OurStory { enabled, title, description }
  scratchReveal  Json?   // { enabled: boolean } — toggles ScratchDateReveal section on external_link pages
  heroConfetti   Json?   // { enabled: boolean } — toggles the curtain-canva hero celebration confetti. Unset → fires (default on)
  countdown      Json?   // ExternalCountdownConfig — toggles and styles the external_link countdown section
  personalGuestCard Json? // PersonalGuestCardConfig — optional background image + scrim behind the personal guest card (video-entrance / curtain-canva)
  textStyles     Json?   // TextStyleOverrides — per-invitation text styling overrides (fonts, colors, sizes)
  cardStyles     Json?   // CardStyleOverrides — per-section card background/border overrides
  imageSettings  Json?   // ImageSettingsMap — per-image position & zoom overrides
  customTexts    Json?   // CustomTexts — per-invitation UI text overrides (section titles, buttons, RSVP labels, etc.)
  eventType      String  @default("wedding") // "wedding" | "anniversary" | "baptism" | "engagement" | "other"
  invitationType String  @default("standard") // "standard" | "external_video" | "external_link"
  externalLink   String? // URL for the external link / iframe (external_link type)
  isDemo         Boolean @default(false)
  guestManagementEnabled Boolean @default(false)
  guestMessageTemplate   String?
  socialPreview Json?    // SocialPreview { image?, title?, description? } — used only for OG/Twitter meta tags

  priceFromCents     Int?
  discountPriceFromCents Int? // sale price in cents; valid only when 0 < discount < priceFromCents
  currency           String  @default("EUR") // base currency; stays "EUR"
  priceOverrides     Json?    // PriceOverrides: { MZN?, AOA?, BRL?, USD? } in minor units; EUR derives from base
  landingModelName   String?
  landingImageUrl    String?
  landingDescription String?
  landingSubtitle    String?

  ownerToken   String   @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rsvpResponses   RsvpResponse[]
  guests          Guest[]
  landingFeatures LandingFeature[]
}

// ---------------------------------------------------------------------------
// Save The Date — separate product type
// ---------------------------------------------------------------------------

model SaveTheDateTheme {
  id          String @id @default(cuid())
  name        String @unique // slug identifier, e.g. "golden-heart"
  label       String
  description String

  // Heart appearance
  heartColor         String // primary heart fill, e.g. "#D4AF37"
  heartGlitterColors Json   // string[] — hex colors for the shimmer gradient
  rsvpButtonBgColor  String @default("#D4AF37") // RSVP button background color
  heartTextureUrl    String? // optional URL to a real glitter texture image

  // Background
  bgColor String // page background color

  // Typography
  titleFont  String // "Save the Date" heading font
  coupleFont String // couple names font
  dateFont   String // revealed date font
  textColor  String // primary text color

  // Confetti
  confettiColors Json // string[] — hex colors for the explosion

  // Envelope cover (same shape as Theme.envelope)
  envelope Json? // { base: string, topFlap: string, bottomFlap: string } — optional envelope cover for STD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saveDates SaveTheDate[]
}

model SaveTheDate {
  id      String @id @default(cuid())
  slug    String @unique
  themeId String
  theme   SaveTheDateTheme @relation(fields: [themeId], references: [id])

  couple        Json    // { bride: string, groom: string }
  date          Json    // { iso: string, display: string, day: string, month: string, year: string }
  location      Json?   // Optional first location card — same shape as Invitation.location
  location2     Json?   // Optional second location card — same shape as Invitation.location2
  customMessage String? // optional text shown after date reveal
  envelope      Json?   // per-STD envelope overrides { base?, coverBackground?, topFlap?, bottomFlap?, shimmer? }
  textStyles    Json?   // per-STD font/size overrides { titleFont?, coupleFont?, dateFont?, titleFontSize?, coupleFontSize?, dateFontSize? }
  rsvp          Json?   // { enabled: boolean, deadline?: string }
  audio         Json?   // { enabled: boolean, src: string, artist: string, title: string }
  bottomHero    Json?   // { enabled: boolean, mediaUrl: string, mediaType: "image"|"video", title: string, description: string }
  socialPreview Json?   // SocialPreview { image?, title?, description? } — used only for OG/Twitter meta tags
  isDemo        Boolean @default(false)

  priceFromCents     Int?
  discountPriceFromCents Int? // sale price in cents; valid only when 0 < discount < priceFromCents
  currency           String  @default("EUR") // base currency; stays "EUR"
  priceOverrides     Json?    // PriceOverrides: { MZN?, AOA?, BRL?, USD? } in minor units; EUR derives from base
  landingModelName   String?
  landingImageUrl    String?
  landingDescription String?
  landingSubtitle    String?

  ownerToken String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rsvpResponses   SaveTheDateRsvpResponse[]
  landingFeatures LandingFeature[]
}

// ---------------------------------------------------------------------------
// RSVP
// ---------------------------------------------------------------------------

model RsvpResponse {
  id                  String   @id @default(cuid())
  invitationSlug      String
  guestName           String
  email               String?
  attending           Boolean
  dietaryRestrictions String?
  message             String?
  customAnswers       Json?
  submittedAt         DateTime @default(now())

  invitation Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  guestId String?
  guest   Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([invitationSlug])
  @@index([guestId])
}

// ---------------------------------------------------------------------------
// Guest management — per-invitation pre-registered guests
// ---------------------------------------------------------------------------

model Guest {
  id              String   @id @default(cuid())
  invitationSlug  String
  invitation      Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  token           String   @unique @default(cuid())

  name            String
  slugifiedName   String
  companion       String?

  phoneCountryCode String
  phoneNumber      String

  tableLabel      String?
  totalGuests     Int?
  canInviteOthers Boolean  @default(false)
  note            String?
  customExternalLink String?

  invitedById   String?
  invitedBy     Guest?  @relation("GuestInvitations", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedGuests Guest[] @relation("GuestInvitations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rsvpResponses RsvpResponse[]

  @@index([invitationSlug])
  @@index([token])
}

model SaveTheDateRsvpResponse {
  id                  String   @id @default(cuid())
  saveTheDateSlug     String
  guestName           String
  email               String?
  attending           Boolean
  dietaryRestrictions String?
  message             String?
  customAnswers       Json?
  submittedAt         DateTime @default(now())

  saveTheDate SaveTheDate @relation(fields: [saveTheDateSlug], references: [slug], onDelete: Cascade)

  @@index([saveTheDateSlug])
}

// ---------------------------------------------------------------------------
// Landing page featured invitations / save-the-dates
// ---------------------------------------------------------------------------

model LandingFeature {
  id              String   @id @default(cuid())
  section         String   // "hero" | "gallery" | "live_demo"
  galleryCategory String?  // "wedding" | "save_the_date" | "baptism" | "anniversary" | "engagement"
  position        Int      @default(0)
  enabled         Boolean  @default(true)

  invitationId    String?
  invitation      Invitation? @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  saveTheDateId   String?
  saveTheDate     SaveTheDate? @relation(fields: [saveTheDateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section, position])
  @@index([galleryCategory])
}

// ---------------------------------------------------------------------------
// Contact submissions — landing page WhatsApp/contact form leads
// ---------------------------------------------------------------------------

model ContactSubmission {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  eventType String
  eventDate DateTime?
  message   String
  source    String    @default("landing")
  status    String    @default("new")
  ipHash    String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
}
