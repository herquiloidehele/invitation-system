generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Theme {
  id          String   @id @default(cuid())
  name        String   @unique // slug identifier, e.g. "pink-floral"
  label       String
  description String

  // Envelope appearance stored as JSON { base, topFlap, bottomFlap }
  envelope Json

  // Page background & card styling
  bg         String
  cardBg     String
  cardBorder String

  // Color palette
  primary   String
  secondary String
  accent    String

  // Text colors
  textPrimary   String
  textSecondary String
  textMuted     String

  // Typography
  displayFont String
  bodyFont    String
  scriptFont  String?
  uiFont      String

  // CTA button styling
  ctaPrimaryBg       String
  ctaPrimaryText     String
  ctaSecondaryBorder String
  ctaSecondaryText   String
  ctaRadius          String

  // Cover text colors
  monogramColor String
  tapTextColor  String

  // Atmospheric / decorative
  bgGradient      String?
  decorativeColor String
  ctaGlow         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invitations Invitation[]
}

model Invitation {
  id           String   @id @default(cuid())
  slug         String   @unique
  themeId      String
  theme        Theme    @relation(fields: [themeId], references: [id])
  couple       Json     // { bride, groom, monogram }
  date         Json     // { iso, display, dayOfWeek, time, day, month, year }
  quote        String
  location     Json     // { name, address, googleMapsUrl, wazeUrl?, latitude?, longitude?, imageUrl? }
  rsvp         Json     // { enabled, deadline? }
  schedule     Json     // ScheduleEvent[]
  dressCode    Json     // { enabled, text }
  giftRegistry Json     // { enabled, text, link? }
  audio        Json     // { enabled, src, artist, title }
  heroImage    String
  videoUrl     String?
  faqs         Json?    // FAQItem[]
  guestGuide   Json?    // GuestGuide { enabled, items[] }
  envelope     Json?    // EnvelopeConfig { base?, topFlap?, bottomFlap? }
  saveDateStyle  String? // "classic" | "countdown" | "quad-cards" | "cinematic" | "minimal-line"
  cinematicImageUrl String? // background image for the cinematic Save the Date style
  sectionImages  Json?   // SectionImages { image1?, image2?, image3?, image4? }
  parents        Json?   // ParentsInfo { enabled, blessingMessage, inviteMessage, bridesFather, bridesMother, groomsFather, groomsMother }
  ourStory       Json?   // OurStory { enabled, title, description }
  textStyles     Json?   // TextStyleOverrides — per-invitation text styling overrides (fonts, colors, sizes)
  invitationType String  @default("standard") // "standard" | "external_video" | "external_link"
  externalLink   String? // URL for the external link / iframe (external_link type)
  ownerToken   String   @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rsvpResponses RsvpResponse[]
  events        InvitationEvent[]
}

model InvitationEvent {
  id             String     @id @default(cuid())
  invitationSlug String
  invitation     Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  /// "page_view" | "envelope_open" | "maps_click" | "waze_click" | "gift_click" | "audio_play" | "calendar_click" | "rsvp_submit"
  type      String
  visitorId String
  sessionId String
  device    String?
  referrer  String?

  createdAt DateTime @default(now())

  @@index([invitationSlug])
  @@index([invitationSlug, type])
  @@index([createdAt])
}

model RsvpResponse {
  id                  String   @id @default(cuid())
  invitationSlug      String
  guestName           String
  email               String?
  attending           Boolean
  dietaryRestrictions String?
  message             String?
  submittedAt         DateTime @default(now())

  invitation Invitation @relation(fields: [invitationSlug], references: [slug], onDelete: Cascade)

  @@index([invitationSlug])
}
